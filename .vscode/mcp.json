      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/Users/Siks_user/Desktop/gamblio-site"
      ]
